{
  "name": "explorer-backend",
  "version": "3.11",
  "description": "Bitcoin Cash Explorer mempool visualizer and blockchain explorer backend",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://bchexplorer.cash",
  "author": "Melroy van den Berg <melroy@melroy.org> (https://melroy.org)",
  "packageManager": "pnpm@11.1.3",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.melroy.org/bitcoincash/bitcoin-cash-explorer"
  },
  "bugs": {
    "url": "https://gitlab.melroy.org/bitcoincash/bitcoin-cash-explorer/issues"
  },
  "keywords": [
    "bitcoin",
    "cash",
    "bitcoin cash",
    "mempool",
    "blockchain",
    "explorer",
    "bch"
  ],
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.build.json",
    "build": "pnpm run typecheck && pnpm run create-resources",
    "clean": "rm -rf ./dist/ ./node_modules/ ./package/ ./rust-gbt/",
    "create-resources": "cp ./src/tasks/price-feeds/mtgox-weekly.json ./dist/tasks && node dist/api/fetch-version.js",
    "dev": "tsx watch src/index.ts",
    "package": "./pnpm_package.sh",
    "package-rm-build-deps": "./pnpm_package_rm_build_deps.sh",
    "preinstall": "cd ../rust/gbt && pnpm run build-release && pnpm run to-backend",
    "start": "node --max-old-space-size=2048 dist/index.js",
    "start-production": "node --max-old-space-size=16384 dist/index.js",
    "reindex-updated-pools": "pnpm run start-production --update-pools",
    "reindex-all-blocks": "pnpm run start-production --update-pools --reindex-blocks",
    "test": "jest --coverage",
    "test:ci": "CI=true jest --coverage",
    "test:integration": "jest --config=jest.integration.config.ts --runInBand --forceExit",
    "test:with-db": "bash ./scripts/test-with-db.sh",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier": "prettier --write \"src/**/*.{js,ts}\"",
    "prettier:check": "prettier --check \"src/**/*.{js,ts}\""
  },
  "dependencies": {
    "@bitcoincash/electrum-client": "^1.2.1",
    "@types/node": "^24.12.4",
    "axios": "1.14.0",
    "bitcoinjs-lib": "~7.0.1",
    "crypto-js": "~4.2.0",
    "express": "~4.22.2",
    "mysql2": "~3.20.0",
    "redis": "^5.12.1",
    "rust-gbt": "file:rust-gbt",
    "socks-proxy-agent": "~8.0.5",
    "typescript": "~5.9.3",
    "ws": "~8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/types": "^30.4.1",
    "@types/compression": "^1.8.1",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/ws": "~8.18.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript-eslint": "^8.60.0"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "glob": "^11.1.0"
  }
}
