{
  "upload": {  
    "type": "xliff",
    "features": ["use_project_lang"],
    "deprecate": "file",
    "files": [
      {
        "pattern": "src/locale/messages.xlf",
        "lang": "inherited"
      },
      {
        "group": "existing",
        "pattern": "src/locale/messages.*.xlf",
        "excludes": ["src/locale/messages.xlf"],
        "lang": "${autodetectLang}"
      }
    ]
  },
  "download": {
    "files": "src/locale/messages.${lang}.xlf"
  }
}