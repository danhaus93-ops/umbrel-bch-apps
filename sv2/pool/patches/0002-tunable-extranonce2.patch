+// LoneStrike patch: the miner-rollable extranonce2 space was a compile-time
+// constant, so operators could not tune it. Read it from the environment
+// (SV2_EXTRANONCE2_BYTES, written by the dashboard via the pool entrypoint)
+// and fall back to upstream's 16 when unset or out of range.
+//
+// Deliberately an env var rather than a config field: a config field means
+// touching PoolConfig, its constructor and serde, and this fork builds in CI
+// with a ~2h turnaround and no local compiler to check against.
+//
+// Bounds: below 4 starves SV1-behind-translator miners of rolling room; above
+// 32 eats the coinbase scriptSig budget (100B total; BIP34 height push + pool
+// tag + this extranonce must all fit; ~44B used at 16).
+pub const CLIENT_SEARCH_SPACE_DEFAULT: u8 = 16;
+pub fn client_search_space_bytes() -> u8 {
+    std::env::var("SV2_EXTRANONCE2_BYTES")
+        .ok()
+        .and_then(|v| v.trim().parse::<u8>().ok())
+        .filter(|n| (4..=32).contains(n))
+        .unwrap_or(CLIENT_SEARCH_SPACE_DEFAULT)
+}
+pub fn full_extranonce_size() -> u8 {
+    POOL_ALLOCATION_BYTES + client_search_space_bytes()
+}
 
